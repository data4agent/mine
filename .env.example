# Mine Agent Configuration

# Platform Service
PLATFORM_BASE_URL=https://api.minework.net
# Test environment:
# PLATFORM_BASE_URL=http://101.47.73.95

# Optional helper identifier.
# The lower-level platform identity is derived from the wallet signer address.
MINER_ID=mine-agent

# AWP Wallet
# Optional: leave this as awp-wallet unless you truly need a custom path.
AWP_WALLET_BIN=awp-wallet
# Get token from: awp-wallet unlock --duration 3600
AWP_WALLET_TOKEN=

# EIP-712 Signature Domain Parameters
# Auto-fetched from the platform and cached locally; do NOT override manually.
# A wrong verifyingContract causes signer_mismatch 401.
# Only uncomment if you know the exact platform values and need to force them.
# EIP712_DOMAIN_NAME=aDATA
# EIP712_CHAIN_ID=8453
# EIP712_VERIFYING_CONTRACT=0xAB41eE5C44D4568aD802D104A6dAB1Fe09C590D1

# Worker Configuration
# CRAWLER_ROOT=./crawlers
# OUTPUT_ROOT=./output
# STATE_ROOT=./state
# PYTHON_BIN=python
# MAX_PARALLEL=3
# DISCOVERY_MAX_PAGES=25
# DISCOVERY_MAX_DEPTH=1
