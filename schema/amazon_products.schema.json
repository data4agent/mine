    },
    "sales_volume_hint": {
      "type": [
        "string",
        "null"
      ],
      "description": "e.g. 10K+ bought in past month"
    },
    "estimated_monthly_sales": {
      "type": [
        "integer",
        "null"
      ]
    },
    "images": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "null"
        ],
        "format": "uri"
      }
    },
    "main_image": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "availability": {
      "type": [
        "string",
        "null"
      ]
    },
    "stock_status": {
      "type": [
        "string",
        "null"
      ]
    },
    "reviews_count": {
