{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Amazon Products Dataset",
  "dedup_key": "asin + marketplace",
  "url_normalize_regex": "^https?://(?:www\\.)?amazon\\.(com|co\\.uk|de|...)/(?:.*/)?(dp|gp/product)/([A-Z0-9]{10})(?:[/?#].*)?$ → https://www.amazon.$1/dp/$3",
  "type": "object",
  "required": [
    "asin",
    "title",
    "dedup_key",
    "canonical_url"
  ],
  "properties": {
    "dedup_key": {
      "type": "string"
    },
    "canonical_url": {
      "type": "string",
      "format": "uri"
    },
    "marketplace": {
      "type": "string"
    },
    "asin": {
      "type": "string"
    },
    "URL": {
      "type": "string",
      "format": "uri"
    },
    "title": {
      "type": "string"
    },
    "brand": {
      "type": [
        "string",
        "null"
      ]
    },
    "seller_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "seller_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "initial_price": {
      "type": [
        "number",
        "null"
      ]
    },
    "final_price": {
      "type": [
        "number",
        "null"
      ]
    },
    "currency": {
      "type": [
        "string",
        "null"
      ]
    },
    "discount": {
      "type": [
        "string",
        "null"
      ]
    },
    "coupon_available": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "subscribe_and_save_available": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "bullet_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "breadcrumbs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "category_tree": {
      "type": [
        "string",
        "null"
      ]
    },
