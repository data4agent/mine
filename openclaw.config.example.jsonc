{
  "plugins": {
    "allow": ["mine"],
    "installs": {
      "mine": {
        "source": "path",
        "path": "D:/kaifa/clawtroop/mine/dist/openclaw-plugin",
        "config": {
          "crawlerRoot": "D:/kaifa/clawtroop/social-data-crawler",
          "pythonBin": "python",
          "platformBaseUrl": "http://101.47.73.95",
          "platformToken": "",
          "minerId": "miner-001",
          "awpWalletBin": "awp-wallet",
          "awpWalletTokenRef": {
            "source": "env",
            "provider": "processenv",
            "id": "AWP_WALLET_TOKEN"
          },
          "outputRoot": "D:/kaifa/clawtroop/social-data-crawler/output/agent-runs",
          "workerStateRoot": "D:/kaifa/clawtroop/social-data-crawler/output/agent-runs/_worker_state",
          "workerMaxParallel": 3,
          "datasetRefreshSeconds": 900,
          "discoveryMaxPages": 25,
          "discoveryMaxDepth": 1,
          "authRetryIntervalSeconds": 300
        }
      }
    }
  },
  "gateway": {
    "auth": {
      "baseUrl": "http://127.0.0.1:18789/v1"
    }
  }
}
